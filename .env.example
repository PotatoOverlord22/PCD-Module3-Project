# ---------------------------------------------------------------------------
# Environment variables for the Caregiver Dashboard project
# ---------------------------------------------------------------------------
# Copy this file to backend/.env and ml-pipeline/.env, then fill in your values.
# These .env files are gitignored and will NOT be committed.
#
# On cloud platforms (GCP Cloud Run, AWS ECS, etc.) inject these as
# environment variables directly — no .env file needed.
# ---------------------------------------------------------------------------

# MongoDB Atlas connection string
# Get yours from: https://cloud.mongodb.com → Connect → Drivers → Python
# Free tier (M0) is sufficient for development.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# MongoDB database name (optional, defaults to "pcd-module3-project")
MONGO_DB_NAME=pcd-module3-project
